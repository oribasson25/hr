generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model HrStaff {
  id         String        @id @default(cuid())
  name       String
  email      String?
  phone      String?
  role       String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  candidates Candidate[]
}

model Job {
  id           String    @id @default(cuid())
  title        String
  description  String
  requirements String
  salaryBudget String?
  status       String    @default("open")
  filledAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  assignments  JobAssignment[]
  reminders    Reminder[]
}

model Candidate {
  id                String   @id @default(cuid())
  fullName          String
  phone             String
  email             String?
  address           String?
  cvFileName        String?
  cvFilePath        String?
  cvFileType        String?
  appliedForCustom  String?
  source            String?
  referredByName    String?
  salaryExpectation String?
  hrStaffId         String?
  hrStaff           HrStaff? @relation(fields: [hrStaffId], references: [id], onDelete: SetNull)
  referredById      String?
  referredBy        Candidate?  @relation("Referrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals         Candidate[] @relation("Referrals")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  assignments       JobAssignment[]
  notes             Note[]
  reminders         Reminder[]
}

model JobAssignment {
  id               String    @id @default(cuid())
  jobId            String
  candidateId      String
  status           String    @default("candidate")
  position         Int       @default(0)
  recruitmentStage String    @default("cv_received")
  rejectionReason  String?
  interviewRating  Int?
  interviewSummary String?
  startDate        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([jobId, candidateId])
}

model Note {
  id          String    @id @default(cuid())
  candidateId String
  content     String
  createdAt   DateTime  @default(now())
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model CvMatchHistory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  entries   Json
}

model Reminder {
  id          String    @id @default(cuid())
  title       String
  isDone      Boolean   @default(false)
  dueDate     DateTime?
  jobId       String?
  candidateId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  job         Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  candidate   Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)
}
